{
  "name": "jsonschema-builder-vue",
  "license": "MIT",
  "description": "Vue 3 Visual JSON Schema editor for creating and manipulating JSON Schema definitions with an intuitive interface.",
  "author": {
    "name": "gcasotti",
    "url": "https://github.com/gcasotti"
  },
  "keywords": [
    "json",
    "schema",
    "editor",
    "visual",
    "vue"
  ],
  "private": false,
  "version": "0.4.5",
  "type": "module",
  "sideEffects": false,
  "repository": {
    "type": "git",
    "url": "git+https://github.com/gcasotti/jsonschema-builder-vue.git"
  },
  "homepage": "https://gcasotti.github.io/jsonschema-builder-vue",
  "files": [
    "dist",
    "!tsconfig.tsbuildinfo",
    "!tsconfig.js"
  ],
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/jsonschema-builder-vue.d.ts",
  "exports": {
    ".": {
      "types": "./dist/jsonschema-builder-vue.d.ts",
      "import": "./dist/index.js",
      "module": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./styles.css": {
      "import": "./dist/index.css",
      "module": "./dist/index.css",
      "default": "./dist/index.css"
    }
  },
  "scripts": {
    "dev": "rsbuild dev",
    "preview": "rsbuild preview",
    "build": "rslib build",
    "build:demo": "rsbuild build",
    "build:dev": "rslib build --mode development",
    "lint": "biome lint .",
    "format": "biome format . --write",
    "check": "biome check .",
    "fix": "biome check --fix --unsafe",
    "typecheck": "vue-tsc --noEmit",
    "test": "tsx --tsconfig tsconfig.test.json --test test/**/*.test.{js,ts}",
    "test:ui": "vitest run",
    "test:all": "npm run test && npm run test:ui",
    "test:snapshots": "tsx --test-update-snapshots --tsconfig tsconfig.test.json --test test/**/*.test.{js,ts}",
    "prepack": "npm run build"
  },
  "dependencies": {
    "@primevue/themes": "^4.3.0",
    "ajv": "^8.17.1",
    "ajv-formats": "^3.0.1",
    "clsx": "^2.1.1",
    "lucide-vue-next": "^0.562.0",
    "monaco-editor": "^0.55.1",
    "primeicons": "^7.0.0",
    "primevue": "^4.3.0",
    "tailwind-merge": "^3.3.1",
    "zod": "^4.0.17"
  },
  "peerDependencies": {
    "vue": ">=3.4.0"
  },
  "devDependencies": {
    "@biomejs/biome": "2.3.10",
    "@microsoft/api-extractor": "^7.52.11",
    "@rsbuild/core": "^1.4.15",
    "@rsbuild/plugin-vue": "^1.0.0",
    "@rslib/core": "^0.19.0",
    "@tailwindcss/postcss": "^4.1.12",
    "@types/node": "^25.0.3",
    "@vitejs/plugin-vue": "^6.0.4",
    "@vue/test-utils": "^2.4.6",
    "happy-dom": "^20.8.3",
    "postcss": "^8.5.6",
    "tailwindcss": "^4.1.12",
    "tsx": "^4.20.6",
    "typescript": "^5.9.2",
    "vitest": "^4.0.18",
    "vue": "^3.5.0",
    "vue-router": "^4.5.0",
    "vue-tsc": "^2.2.0"
  },
  "packageManager": "npm@10.9.3+sha512.e84875bb943e908557780f1eee5d9cfc7a67145730ae4b77ef10ccba30f96ded6096859af69ea3dc5b2fde60725d79aa247cbed9c12544c30bf28a4d4fbc4825"
}
